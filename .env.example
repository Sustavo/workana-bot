# ── Gemini ────────────────────────────────────────────────
# Pegue em https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Modelo Gemini. Padrão balanceia custo/qualidade.
GEMINI_MODEL=gemini-2.5-flash-lite

# ── Workana ───────────────────────────────────────────────
# URL do feed de vagas com seus filtros já aplicados.
WORKANA_JOBS_URL=https://www.workana.com/jobs?category=it-programming&language=en%2Cpt

# Seu user ID do Workana (hash da URL do perfil /freelancer/<hash>).
WORKANA_USER_ID=

# ── Browser ───────────────────────────────────────────────
# Pasta do perfil persistente do Chromium. Não apagar entre runs.
CHROME_PROFILE_DIR=./data/chrome-profile

# false = vê a janela do browser (recomendado no começo).
HEADLESS=false

# ── Comportamento ─────────────────────────────────────────
# Máx. de drafts gerados por execução. Plano Explorer = 52/semana.
MAX_DRAFTS_PER_RUN=8

# Delays entre ações (segundos). Jitter aleatório nessa faixa.
# Defaults baixos (0.5-1.5s) porque navegação é na mesma sessão autenticada.
# Aumente (ex.: 3-9) se a Workana começar a detectar bot.
MIN_DELAY_SECONDS=0.5
MAX_DELAY_SECONDS=1.5

# Preencher o campo "Prazo de entrega" no bid form?
# false (padrão) = deixa em branco. true = preenche com o valor gerado pelo Gemini.
FILL_DELIVERY_TIME=false

# ── Infra ─────────────────────────────────────────────────
DATABASE_PATH=./data/workana.db
LOG_LEVEL=INFO
LOG_FILE=./data/logs/run.log
