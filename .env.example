# ── Gemini ────────────────────────────────────────────────
# Pegue em https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Modelo Gemini. Padrão balanceia custo/qualidade.
GEMINI_MODEL=gemini-2.5-flash-lite

# ── Workana ───────────────────────────────────────────────
# URL do feed de vagas com seus filtros já aplicados.
WORKANA_JOBS_URL=https://www.workana.com/jobs?category=it-programming&language=en%2Cpt

# Seu user ID do Workana (hash da URL do perfil /freelancer/<hash>).
WORKANA_USER_ID=

# ── Browser ───────────────────────────────────────────────
# Pasta do perfil persistente do Chromium. Não apagar entre runs.
CHROME_PROFILE_DIR=./data/chrome-profile

# false = vê a janela do browser (recomendado no começo).
HEADLESS=false

# ── Comportamento ─────────────────────────────────────────
# Máx. de drafts gerados por execução. Plano Explorer = 52/semana.
MAX_DRAFTS_PER_RUN=8

# Perfil de velocidade (anti-ban): conservador | equilibrado | rapido
#   conservador → delay 4-10s, pausas longas frequentes, teto 40 ações/h (mais seguro)
#   equilibrado → delay 2.5-6s, pausas ocasionais, teto 90 ações/h (default)
#   rapido      → delay 0.5-1.5s, sem pausas/teto (rápido, MAIS risco de ban)
# Pode sobrepor na hora: python -m src.main scrape --speed conservador
SPEED_PROFILE=equilibrado

# (Opcional) Overrides finos — descomente só se quiser ajustar manualmente.
# Se descomentados, GANHAM do perfil acima.
# MIN_DELAY_SECONDS=2.5
# MAX_DELAY_SECONDS=6
# LONG_PAUSE_CHANCE=0.12        # prob. (0..1) de pausa longa extra por ação
# LONG_PAUSE_MIN_SECONDS=15
# LONG_PAUSE_MAX_SECONDS=45
# MAX_ACTIONS_PER_HOUR=90       # 0 = sem teto

# Detector de bloqueio/captcha/atividade suspeita do Workana (recomendado: true).
GUARD_ENABLED=true

# Tempo (ms) pra confirmar o redirect após 'Enviar orçamento'.
SUBMIT_REDIRECT_TIMEOUT_MS=25000

# Preencher o campo "Prazo de entrega" no bid form?
# false (padrão) = deixa em branco. true = preenche com o valor gerado pelo Gemini.
FILL_DELIVERY_TIME=false

# ── Infra ─────────────────────────────────────────────────
DATABASE_PATH=./data/workana.db
LOG_LEVEL=INFO
LOG_FILE=./data/logs/run.log
